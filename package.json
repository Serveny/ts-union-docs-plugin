{
    "name": "ts-union-docs-plugin",
    "version": "0.3.1",
    "publisher": "Serveny",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist",
        "README.md"
    ],
    "prepublishOnly": "npm run build",
    "repository": {
        "type": "git",
        "url": "https://github.com/Serveny/ts-union-docs-plugin"
    },
    "devDependencies": {
        "@types/node": "25.5.0",
        "@vitest/ui": "^4.1.1",
        "rollup-plugin-node-externals": "8.1.2",
        "typescript": "6.0.2",
        "vite": "8.0.2",
        "vite-plugin-dts": "4.5.4",
        "vitest": "^4.1.1"
    },
    "scripts": {
        "check": "tsc --noEmit",
        "build": "vite build",
        "watch": "vite",
        "refresh": "npm run build && cd ../example && npm i",
        "watch-and-refresh": "npx nodemon -w ./src -e ts -x \"npm run build && cd ../example && npm i\"",
        "debug": "TSS_DEBUG=5667 code ../example --user-data-dir ~/.vscode-debug/ --disable-extensions",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:ui": "vitest --ui"
    }
}